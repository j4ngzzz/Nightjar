# Nightjar Verification Canvas — Environment Variables
# Copy to .env.local and fill in values

# FastAPI backend URL (defaults to localhost:8000 for local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Enable GitHub OAuth (optional — auth is gated behind this flag)
NEXT_PUBLIC_ENABLE_AUTH=false

# GitHub OAuth credentials (only needed if NEXT_PUBLIC_ENABLE_AUTH=true)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# Optional: Sentry DSN for frontend error tracking
# NEXT_PUBLIC_SENTRY_DSN=
